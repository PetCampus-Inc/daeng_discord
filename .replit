modules = ["nodejs-20", "python-3.11"]
[agent]
expertMode = true
integrations = ["jira:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard"

[[workflows.workflow]]
name = "Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
CONTRIBUTOR_ROLE_ID = "1467352079927611527"
